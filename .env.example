# --- Server ---
PORT=8080
ENV=development
# Prod CORS: ruxsat etilgan originlar (vergul bilan). Bo'sh → hammaga ruxsat (dev).
# CORS_ORIGINS=https://quizarena.app,https://t.me

# --- Docker host portlari (boshqa loyihalar bilan to'qnashmasligi uchun) ---
# Konteyner ichidagi portlar o'zgarmaydi; bular faqat host tarafdagi map.
WEB_PORT=8090        # frontend (nginx) — brauzerda http://server-ip:8090
APP_PORT=8080        # backend REST/WS
DB_PORT=5432         # postgres (host'dan migratsiya/seed uchun)

# --- PostgreSQL ---
# Lokal (make run) uchun localhost; docker-compose ichida host = postgres
DATABASE_URL=postgres://quizarena:quizarena@localhost:5432/quizarena?sslmode=disable

# --- Auth ---
JWT_SECRET=change-me-in-prod

# --- Telegram (Bosqich 2) ---
TELEGRAM_BOT_TOKEN=

# --- Media saqlash (Bosqich 6, MinIO/S3) ---
# S3_ENDPOINT=
# S3_BUCKET=
